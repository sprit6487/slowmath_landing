{
  "rewrites": [
    {
      "source": "/slowmath_:app/:path*",
      "destination": "https://slowmath-all.vercel.app/slowmath_:app/:path*"
    }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
